# === 应用配置 ===
APP_NAME=TaobaoProductMonitor
LOG_LEVEL=INFO
DEBUG=false

# === 数据库配置 ===
DB_TYPE=sqlite
DB_SQLITE_PATH=db/ProductMonitor.db
# DB_TYPE=mysql
# DB_MYSQL_HOST=localhost
# DB_MYSQL_PORT=3306
# DB_MYSQL_USER=root
# DB_MYSQL_PASSWORD=yourpassword
# DB_MYSQL_DATABASE=product_monitor

# === 淘宝 API 配置 ===
TAOBAO_APP_KEY=12574478
TAOBAO_REQUEST_INTERVAL=3.0
TAOBAO_MAX_RETRIES=3
TAOBAO_TIMEOUT=10

# === 代理配置 ===
PROXY_ENABLED=false
PROXY_HOST=127.0.0.1
PROXY_PORT=7890

# === Playwright 配置 ===
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SLOW_MO=0

# === 邮件配置 ===
MAIL_HOST=smtp.163.com
MAIL_PORT=25
MAIL_SENDER=your@163.com
MAIL_LICENSE_KEY=your_license_key
